{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/cron/morning-dm",
      "schedule": "30 3 * * 1-5"
    },
    {
      "path": "/api/cron/eod-followup",
      "schedule": "30 14 * * 1-5"
    },
    {
      "path": "/api/cron/lakshay-eod",
      "schedule": "30 15 * * 1-5"
    }
  ]
}
